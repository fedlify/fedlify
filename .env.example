# Web application
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-32-bytes
DATABASE_URL=postgresql://fedlify:fedlify@localhost:5432/fedlify

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Object storage, S3-compatible. MinIO works locally.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=fedlify-artifacts
S3_ACCESS_KEY_ID=fedlify
S3_SECRET_ACCESS_KEY=fedlify-secret
S3_FORCE_PATH_STYLE=true

# Email invitations
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Fedlify <no-reply@fedlify.local>"

# Argo and worker integration
ARGO_WEBHOOK_SECRET=replace-with-shared-secret
AGENT_WORKFLOW_NAMESPACE=argo
AGENT_WORKFLOW_TEMPLATE=fedlify-agent-kit-generation
FEDLIFY_REQUIRE_NVFLARE=false

# Real runtime pilot
GITEA_BASE_URL=
GITEA_TOKEN=
GITEA_ORG=
GITEA_PUBLIC_TEMPLATE_ORG=fedlify-templates
GITEA_STUDY_ORG_PREFIX=fedlify-study
GITEA_PIPELINE_REPO_PREFIX=pipeline
OPENAI_API_KEY=
OPENAI_CODE_AGENT_MODEL=gpt-5.4
FEDLIFY_RUNTIME_MODE=local-docker
FEDLIFY_RUNTIME_ROOT=.fedlify-runtime
FEDLIFY_PUBLIC_BASE_URL=http://localhost:3000
NVFLARE_PUBLIC_HOST=localhost
NVFLARE_PORT_BASE=18000
NVFLARE_ADMIN_EMAIL=admin@fedlify.local
NVFLARE_FLARE_API_BASE_URL=http://localhost:3010
NVFLARE_PYTHON=/opt/homebrew/opt/python@3.9/bin/python3.9
NVFLARE_DOCKER_IMAGE=fedlify-nvflare:2.6.2
